{
  "name": "naval-defence-management-tool",
  "version": "1.1.6",
  "description": "Naval Defence Alliance management tool (buyback, moon, doctrines, readiness)",
  "author": "SushiandSushi",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "test:py": "python -m pytest python/tests -v",
    "build:python": "pyinstaller python/sidecar.spec --distpath build/python-sidecar --workpath build/pyinstaller-work --clean --noconfirm",
    "build:mac": "npm run build:python && electron-builder --mac --publish never",
    "build:win": "npm run build:python && electron-builder --win --publish never",
    "build": "npm run build:mac"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "org.navaldefence.management-tool",
    "productName": "Naval Defence Alliance Management Tool",
    "afterSign": "electron/afterSign.js",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/python-sidecar",
        "to": "python-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
